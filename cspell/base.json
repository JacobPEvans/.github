{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "import": [
    "@cspell/dict-aws/cspell-ext.json",
    "@cspell/dict-bash/cspell-ext.json",
    "@cspell/dict-companies/cspell-ext.json",
    "@cspell/dict-data-science/cspell-ext.json",
    "@cspell/dict-docker/cspell-ext.json",
    "@cspell/dict-filetypes/cspell-ext.json",
    "@cspell/dict-git/cspell-ext.json",
    "@cspell/dict-html/cspell-ext.json",
    "@cspell/dict-k8s/cspell-ext.json",
    "@cspell/dict-markdown/cspell-ext.json",
    "@cspell/dict-node/cspell-ext.json",
    "@cspell/dict-npm/cspell-ext.json",
    "@cspell/dict-python/cspell-ext.json",
    "@cspell/dict-shell/cspell-ext.json",
    "@cspell/dict-software-terms/cspell-ext.json",
    "@cspell/dict-terraform/cspell-ext.json",
    "@cspell/dict-typescript/cspell-ext.json"
  ],
  "dictionaryDefinitions": [
    {
      "name": "jpe-ai-llm",
      "path": "./dicts/ai-llm.txt",
      "addWords": false,
      "description": "JacobPEvans org: AI/LLM/agentic terminology (Claude, Anthropic, MCP, MLX, etc.)"
    },
    {
      "name": "jpe-infrastructure",
      "path": "./dicts/infrastructure.txt",
      "addWords": false,
      "description": "JacobPEvans org: infra tooling (Proxmox, Splunk, Cribl, Ansible, Doppler, etc.)"
    },
    {
      "name": "jpe-devtools",
      "path": "./dicts/devtools.txt",
      "addWords": false,
      "description": "JacobPEvans org: dev/CI tooling (linters, test runners, release automation)"
    },
    {
      "name": "jpe-nix",
      "path": "./dicts/nix-ecosystem.txt",
      "addWords": false,
      "description": "JacobPEvans org: Nix / NixOS / nix-darwin / flakes terminology"
    },
    {
      "name": "jpe-org",
      "path": "./dicts/org.txt",
      "addWords": false,
      "description": "JacobPEvans org: identifiers, project names, and shared code references"
    }
  ],
  "dictionaries": [
    "aws",
    "bash",
    "companies",
    "data-science",
    "docker",
    "filetypes",
    "git",
    "html",
    "k8s",
    "markdown",
    "node",
    "npm",
    "python",
    "shell",
    "softwareTerms",
    "terraform",
    "typescript",
    "jpe-ai-llm",
    "jpe-infrastructure",
    "jpe-devtools",
    "jpe-nix",
    "jpe-org"
  ],
  "ignorePaths": [
    ".git",
    "node_modules",
    "*.lock",
    "*.lockb",
    "LICENSE",
    "pnpm-lock.yaml",
    "package-lock.json",
    "yarn.lock",
    "uv.lock",
    "Cargo.lock",
    "poetry.lock",
    "flake.lock"
  ]
}
